<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1680" height="1040" viewBox="0 0 1680 1040" role="img" aria-labelledby="title desc">
  <title id="title">Llens Test Explorer Windows Maquette</title>
  <desc id="desc">Windows desktop maquette for a token-saving test explorer. The design keeps the test catalog visible, shows classic versus compact versus hybrid comparison, and moves verbose details into local tabs for the selected test only.</desc>

  <defs>
    <linearGradient id="windowBg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#f7f4ec" />
      <stop offset="100%" stop-color="#ece7dc" />
    </linearGradient>
    <linearGradient id="headerBg" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#24353f" />
      <stop offset="100%" stop-color="#355361" />
    </linearGradient>
    <filter id="softShadow" x="-10%" y="-10%" width="120%" height="120%">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#25313a" flood-opacity="0.12" />
    </filter>
    <style>
      .ui { font-family: "Segoe UI", Tahoma, sans-serif; fill: #223037; }
      .mono { font-family: Consolas, "Courier New", monospace; fill: #26353d; }
      .title { font-size: 20px; font-weight: 700; letter-spacing: 0.2px; }
      .subtitle { font-size: 11px; fill: #677881; }
      .cardTitle { font-size: 13px; font-weight: 700; fill: #203038; }
      .label { font-size: 11px; fill: #66767f; }
      .value { font-size: 12px; fill: #1c2e35; }
      .tableHead { font-size: 11px; font-weight: 700; fill: #51656e; }
      .small { font-size: 10px; fill: #677881; }
      .chipText { font-size: 10px; font-weight: 700; }
      .tabText { font-size: 11px; font-weight: 700; }
    </style>
  </defs>

