{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Llens": {
    "DbPath": "llens.db",
    "Repos": [
      {
        "Name": "example",
        "Path": "/path/to/your/repo",
        "IncludeExtensions": [ ".cs", ".ts", ".py", ".go" ],
        "ExcludePaths": [ "bin", "obj", "node_modules", ".git" ]
      }
    ]
  }
}
