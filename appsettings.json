{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Llens": {
    "DbPath": "llens.db",
    "Repos": [
      {
        "Name": "my-csharp-project",
        "Path": "/path/to/csharp/repo",
        "Languages": [ "CSharp" ],
        "ExcludePaths": [ "bin", "obj", ".git" ]
      },
      {
        "Name": "my-rust-project",
        "Path": "/path/to/rust/repo",
        "Languages": [ "Rust" ],
        "ExcludePaths": [ "target", ".git" ]
      }
    ]
  }
}
